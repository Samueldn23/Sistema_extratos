# Porta do servidor (Railway define automaticamente)
PORT=3000

# Chave secreta para assinar os tokens JWT
# OBRIGATÓRIO em produção: gere uma string aleatória segura
# Exemplo: openssl rand -base64 64
JWT_SECRET=troque_por_uma_chave_secreta_forte_aqui

# Caminho do banco de dados SQLite
# Em produção (Railway): aponte para o volume persistente, ex: /data/sistema_extratos.db
# Em desenvolvimento local: deixe em branco para usar o padrão (banco/sistema_extratos.db)
DB_PATH=
